---
eleventyExcludeFromCollections: true
permalink: false
---
<!DOCTYPE html>
<html lang="uk">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>{% if seo.metaTitle %}{{ seo.metaTitle }}{% else %}{{ title }}{% endif %} — Мар'яна Вербицька</title>
  <meta name="description" content="{{ seo.excerpt }}">
  <meta name="author" content="Мар'яна Вербицька">
  <meta name="robots" content="index, follow">
  <link rel="canonical" href="https://marianasense.com/blog/{{ page.fileSlug }}/">

  <link rel="icon" type="image/x-icon" href="/favicon.ico">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">

  <!-- Open Graph -->
  <meta property="og:type" content="article">
  <meta property="og:url" content="https://marianasense.com/blog/{{ page.fileSlug }}/">
  <meta property="og:title" content="{% if seo.metaTitle %}{{ seo.metaTitle }}{% else %}{{ title }}{% endif %}">
  <meta property="og:description" content="{{ seo.excerpt }}">
  <meta property="og:image" content="https://marianasense.com{% if cover %}{{ cover }}{% else %}/og-image-v2.jpg{% endif %}">
  <meta property="og:locale" content="uk_UA">
  <meta property="article:published_time" content="{{ date | dateISO }}">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ title }}">
  <meta name="twitter:description" content="{{ seo.excerpt }}">
  <meta name="twitter:image" content="https://marianasense.com{% if cover %}{{ cover }}{% else %}/og-image-v2.jpg{% endif %}">

  <!-- Structured data: стаття -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "{{ title }}",
    "description": "{{ seo.excerpt }}",
    "datePublished": "{{ date | dateISO }}",
    "author": { "@type": "Person", "name": "Мар'яна Вербицька" },
    "publisher": { "@type": "Person", "name": "Мар'яна Вербицька" },
    "mainEntityOfPage": "https://marianasense.com/blog/{{ page.fileSlug }}/"
  }
  </script>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">

  <style>
    :root {
      --cream: #f0ebe3;
      --cream-dark: #e8e0d4;
      --beige-light: #ede5d8;
      --green-sage: #7a9485;
      --green-dark: #3d5245;
      --green-light: #e3ede7;
      --forest: #2e3830;
      --text-body: #556159;
      --text-muted: #7a9485;
      --border: #d8d0c4;
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      background: var(--cream);
      font-family: 'DM Sans', sans-serif;
      color: var(--text-body);
      line-height: 1.7;
      font-weight: 300;
    }
    a { color: var(--green-dark); }

    /* Шапка */
    header {
      display: flex; align-items: center; justify-content: space-between;
      padding: 20px 6vw; border-bottom: 1px solid var(--border);
      position: sticky; top: 0; background: rgba(240,235,227,0.92);
      backdrop-filter: blur(8px); z-index: 50;
    }
    .logo { display: flex; align-items: center; gap: 10px; text-decoration: none; }
    .logo img { width: 34px; height: 34px; }
    .logo span {
      font-family: 'Cormorant Garamond', serif; font-size: 22px;
      color: var(--forest); font-weight: 500;
    }
    .logo em { color: var(--green-sage); font-style: italic; font-weight: 400; }
    .nav-back {
      font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase;
      text-decoration: none; color: var(--green-dark); border: 1px solid var(--green-dark);
      padding: 9px 22px; border-radius: 30px; transition: all 0.2s;
    }
    .nav-back:hover { background: var(--green-dark); color: var(--cream); }

    /* Стаття */
    article { max-width: 720px; margin: 0 auto; padding: 64px 24px 80px; }
    .meta {
      font-size: 12px; letter-spacing: 0.1em; text-transform: uppercase;
      color: var(--green-sage); margin-bottom: 20px;
      display: flex; gap: 16px; align-items: center; flex-wrap: wrap;
    }
    .meta .cat { color: var(--green-dark); font-weight: 500; }
    h1 {
      font-family: 'Cormorant Garamond', serif; font-weight: 400;
      font-size: clamp(32px, 6vw, 52px); line-height: 1.12;
      color: var(--forest); margin-bottom: 28px;
    }
    .lead {
      font-size: 19px; color: var(--green-dark); font-weight: 400;
      border-left: 3px solid var(--green-mid, #b8cfc0); padding-left: 20px;
      margin-bottom: 44px; line-height: 1.6;
    }
    .body h2 {
      font-family: 'Cormorant Garamond', serif; font-weight: 500;
      font-size: 30px; color: var(--forest); margin: 44px 0 16px;
    }
    .body h3 {
      font-family: 'Cormorant Garamond', serif; font-weight: 500;
      font-size: 23px; color: var(--green-dark); margin: 32px 0 12px;
    }
    .body p { margin-bottom: 22px; font-size: 17px; }
    .body ul, .body ol { margin: 0 0 22px 24px; }
    .body li { margin-bottom: 10px; font-size: 17px; }
    .body blockquote {
      border-left: 3px solid var(--green-sage); padding: 4px 0 4px 24px;
      margin: 32px 0; font-family: 'Cormorant Garamond', serif;
      font-style: italic; font-size: 22px; color: var(--green-dark);
    }
    .body img { max-width: 100%; border-radius: 10px; margin: 28px 0; }

    /* CTA в кінці */
    .cta {
      margin-top: 64px; padding: 40px; background: var(--green-light);
      border-radius: 16px; text-align: center;
    }
    .cta p {
      font-family: 'Cormorant Garamond', serif; font-size: 24px;
      color: var(--forest); margin-bottom: 24px; font-weight: 400;
    }
    .cta a {
      display: inline-block; background: var(--green-dark); color: var(--cream);
      text-decoration: none; padding: 14px 36px; border-radius: 30px;
      font-size: 13px; letter-spacing: 0.08em; text-transform: uppercase;
      transition: background 0.2s;
    }
    .cta a:hover { background: var(--forest); }

    /* Футер */
    footer {
      border-top: 1px solid var(--border); padding: 40px 6vw;
      text-align: center; font-size: 13px; color: var(--text-muted);
    }
    footer a { color: var(--green-dark); text-decoration: none; margin: 0 8px; }
  </style>
</head>
<body>
  <header>
    <a class="logo" href="/">
      <img src="/favicon-512.png" alt="Логотип Мар'яна Вербицька">
      <span>Мар'яна <em>Вербицька</em></span>
    </a>
    <a class="nav-back" href="/blog/">← Усі статті</a>
  </header>

  <article>
    <div class="meta">
      <span class="cat">{{ category }}</span>
      <time datetime="{{ date | dateISO }}">{{ date | dateUkr }}</time>
      {% if readingTime %}<span>{{ readingTime }}</span>{% endif %}
    </div>
    <h1>{{ title }}</h1>
    {% if seo.excerpt %}<p class="lead">{{ seo.excerpt }}</p>{% endif %}
    <div class="body">
      {{ content | safe }}
    </div>

    <div class="cta">
      <p>Якщо відгукнулося — можемо поговорити особисто</p>
      <a href="https://booking.easyweek.com.ua/mariana-verbicka-psixolog">Записатися на консультацію</a>
    </div>
  </article>

  <footer>
    <div>
      <a href="/">Головна</a>
      <a href="/blog/">Блог</a>
      <a href="https://instagram.com/maryana_vinka">Instagram</a>
      <a href="https://t.me/Maryana_Vi">Telegram</a>
    </div>
    <p style="margin-top:16px;">© 2026 marianasense.com — простір, де стає легше</p>
  </footer>
</body>
</html>
